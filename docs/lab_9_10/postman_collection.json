      "name": "Cart - AJAX Add Product",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/cart/ajaxadd/{{productId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "cart",
            "ajaxadd",
            "{{productId}}"
          ]
        },
        "description": "Adds one product item to the cart. Works for both guest and authenticated users."
      },
      "response": [
        {
          "name": "Success Example",
          "originalRequest": {
